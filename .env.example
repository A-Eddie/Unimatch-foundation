# Copy this file to .env and fill in your real Safaricom Daraja values.
# Never put these values inside index.html or any frontend JavaScript.

# Use "sandbox" while testing. Use "production" after Safaricom approves your app.
DARAJA_ENV=sandbox

# Put your consumer key and consumer secret here.
# Daraja portal: My Apps -> your app -> Consumer Key / Consumer Secret.
DARAJA_CONSUMER_KEY=put_your_consumer_key_here
DARAJA_CONSUMER_SECRET=put_your_consumer_secret_here

# For sandbox STK Push, Safaricom commonly uses shortcode 174379.
# For production, use your approved Paybill/Till shortcode.
DARAJA_SHORTCODE=174379

# Put your Daraja Lipa na M-Pesa Online passkey here.
DARAJA_PASSKEY=put_your_lipa_na_mpesa_online_passkey_here

# CustomerPayBillOnline for Paybill. CustomerBuyGoodsOnline for Till/Buy Goods.
DARAJA_TRANSACTION_TYPE=CustomerPayBillOnline

# This must be a publicly reachable HTTPS URL in real Daraja testing/production.
# Localhost callbacks will not be reachable by Safaricom.
DARAJA_CALLBACK_URL=https://your-domain.example.com/api/mpesa/callback

# Optional defaults shown in the payment request.
MPESA_ACCOUNT_REFERENCE=NEXUS-DONATE
MPESA_TRANSACTION_DESCRIPTION=Donation to Unimatch Nexus Foundation

# Bank transfer details returned to donors who choose Bank Transfer.
BANK_NAME=Your Bank Name
BANK_ACCOUNT_NAME=Unimatch Nexus Foundation
BANK_ACCOUNT_NUMBER=Your Account Number
BANK_BRANCH=Your Branch
BANK_SWIFT_CODE=Optional Swift Code

# Optional checkout links for card and wallet methods.
# Use real provider-hosted checkout/payment links from Stripe, Flutterwave, Pesapal, DPO, PayPal, or another processor.
STRIPE_PAYMENT_LINK=https://checkout.stripe.com/your-foundation-payment-link
CARD_PAYMENT_URL=https://your-card-processor.example.com/pay
PAYPAL_DONATE_URL=https://www.paypal.com/donate/?hosted_button_id=your_button_id
GOOGLE_PAY_PAYMENT_URL=https://your-google-pay-provider.example.com/pay
